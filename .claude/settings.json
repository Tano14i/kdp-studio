{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/skills && ln -sfn /home/user/kdp-studio/skills/fabio-kdp ~/.claude/skills/fabio-kdp"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/user/kdp-studio/.claude/skill-args-sanitizer.py"
          }
        ]
      }
    ]
  }
}
